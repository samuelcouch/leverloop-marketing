---
import Layout from '../layouts/Layout.astro';
import TermsPage from '../components/landing/TermsPage';
import { termsPageData } from '../data/terms';

const { meta } = termsPageData;

const siteUrl = Astro.site ?? new URL('https://leverloop.com');
const pageUrl = new URL('/terms-and-conditions', siteUrl).href;

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	name: meta.title,
	description: meta.description,
	url: pageUrl,
	isPartOf: { "@type": "WebSite", name: "LeverLoop", url: siteUrl.toString() },
};
---

<Layout title={meta.title} description={meta.description} jsonLd={jsonLd}>
	<TermsPage />
</Layout>
